<!-- app/views/products/_form.html.erb -->
<div class="max-w-xl mx-auto p-6 bg-white rounded-xl shadow-md space-y-4">
  <%= form_with(model: product, local: true) do |form| %>
    <% if product.errors.any? %>
      <div class="bg-red-100 text-red-700 p-4 rounded">
        <h2><%= pluralize(product.errors.count, "error") %> prohibited this product from being saved:</h2>
        <ul>
          <% product.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div>
      <%= form.label :type, class: "block text-sm font-medium" %>
      <%= form.select :type, ["Book", "Electronic", "Clothing"], {}, class: "mt-1 block w-full border-gray-300 rounded-md shadow-sm" %>
    </div>

    <div>
      <%= form.label :name, class: "block text-sm font-medium" %>
      <%= form.text_field :name, class: "mt-1 block w-full border-gray-300 rounded-md shadow-sm" %>
    </div>

    <div>
      <%= form.label :description, class: "block text-sm font-medium" %>
      <%= form.text_area :description, rows: 3, class: "mt-1 block w-full border-gray-300 rounded-md shadow-sm" %>
    </div>

    <div>
      <%= form.label :price, class: "block text-sm font-medium" %>
      <%= form.number_field :price, step: 0.01, class: "mt-1 block w-full border-gray-300 rounded-md shadow-sm" %>
    </div>

    <div class="pt-4">
      <%= form.submit class: "bg-blue-600 text-white px-4 py-2 rounded hover:bg-blue-700" %>
    </div>
  <% end %>
</div>
