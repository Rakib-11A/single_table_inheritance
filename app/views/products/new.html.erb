<!-- app/views/products/new.html.erb -->
<div class="max-w-xl mx-auto bg-white shadow-md rounded-lg p-6">
  <h2 class="text-2xl font-bold mb-6">New Product</h2>

  <%= form_with(model: @product, local: true) do |form| %>
    <div class="mb-4">
      <%= form.label :type, class: "block text-sm font-medium text-gray-700" %>
      <%= form.select :type, ['Book', 'Electronic', 'Clothing'], {}, class: "mt-1 block w-full border-gray-300 rounded-md shadow-sm focus:ring-indigo-500 focus:border-indigo-500" %>
    </div>

    <div class="mb-4">
      <%= form.label :name, class: "block text-sm font-medium text-gray-700" %>
      <%= form.text_field :name, class: "mt-1 block w-full border-gray-300 rounded-md shadow-sm" %>
    </div>

    <div class="mb-4">
      <%= form.label :description, class: "block text-sm font-medium text-gray-700" %>
      <%= form.text_area :description, class: "mt-1 block w-full border-gray-300 rounded-md shadow-sm" %>
    </div>

    <div class="mb-4">
      <%= form.label :price, class: "block text-sm font-medium text-gray-700" %>
      <%= form.number_field :price, step: 0.01, class: "mt-1 block w-full border-gray-300 rounded-md shadow-sm" %>
    </div>

    <!-- Book Fields -->
    <div class="mb-4">
      <%= form.label :author, class: "block text-sm font-medium text-gray-700" %>
      <%= form.text_field :author, class: "mt-1 block w-full border-gray-300 rounded-md shadow-sm" %>
    </div>
    <div class="mb-4">
      <%= form.label :isbn, class: "block text-sm font-medium text-gray-700" %>
      <%= form.text_field :isbn, class: "mt-1 block w-full border-gray-300 rounded-md shadow-sm" %>
    </div>
    <div class="mb-4">
      <%= form.label :pages, class: "block text-sm font-medium text-gray-700" %>
      <%= form.number_field :pages, class: "mt-1 block w-full border-gray-300 rounded-md shadow-sm" %>
    </div>

    <!-- Electronic Fields -->
    <div class="mb-4">
      <%= form.label :brand, class: "block text-sm font-medium text-gray-700" %>
      <%= form.text_field :brand, class: "mt-1 block w-full border-gray-300 rounded-md shadow-sm" %>
    </div>
    <div class="mb-4">
      <%= form.label :model, class: "block text-sm font-medium text-gray-700" %>
      <%= form.text_field :model, class: "mt-1 block w-full border-gray-300 rounded-md shadow-sm" %>
    </div>
    <div class="mb-4">
      <%= form.label :warranty_months, class: "block text-sm font-medium text-gray-700" %>
      <%= form.number_field :warranty_months, class: "mt-1 block w-full border-gray-300 rounded-md shadow-sm" %>
    </div>

    <!-- Clothing Fields -->
    <div class="mb-4">
      <%= form.label :size, class: "block text-sm font-medium text-gray-700" %>
      <%= form.text_field :size, class: "mt-1 block w-full border-gray-300 rounded-md shadow-sm" %>
    </div>
    <div class="mb-4">
      <%= form.label :color, class: "block text-sm font-medium text-gray-700" %>
      <%= form.text_field :color, class: "mt-1 block w-full border-gray-300 rounded-md shadow-sm" %>
    </div>
    <div class="mb-6">
      <%= form.label :material, class: "block text-sm font-medium text-gray-700" %>
      <%= form.text_field :material, class: "mt-1 block w-full border-gray-300 rounded-md shadow-sm" %>
    </div>

    <div class="flex justify-end">
      <%= form.submit "Create Product", class: "bg-indigo-600 text-white px-4 py-2 rounded hover:bg-indigo-700" %>
    </div>
  <% end %>
</div>
